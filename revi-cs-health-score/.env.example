# Token do HubSpot Private App
# Crie em: HubSpot > Settings > Integrations > Private Apps > Create
# Escopos necessarios: crm.objects.companies.read, crm.objects.deals.read,
#   crm.objects.contacts.read, crm.objects.owners.read
HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Jira — Abertura de Tickets
# JIRA_URL: URL base da sua instancia (ex: https://suaempresa.atlassian.net)
# JIRA_EMAIL: email da conta usada para autenticar
# JIRA_API_TOKEN: crie em https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_PROJECT_KEY: chave do projeto no Jira (ex: CS, SUPORTE, REV)
JIRA_URL=https://suaempresa.atlassian.net
JIRA_EMAIL=seu@email.com
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
JIRA_PROJECT_KEY=CS
