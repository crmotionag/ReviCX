<div class="post-card post-card--small post-card--thumbnail-no w-animate" itemscope itemtype="http://schema.org/BlogPosting" data-animate-style="no">
	    <div class="post-card__body">
        <div class="post-card__meta"></div><div class="post-card__title" itemprop="name"> <span class="time-main-label">16:16</span> <span itemprop="headline"><a href="https://reform.news/v-magazine-krasnopolja-nashli-tysjachi-tovarov-bez-markirovki-i-cennikov">В магазине Краснополья нашли тысячи товаров без маркировки и ценников</a></span></div>    </div>
            <meta itemprop="articleBody" content="Комитет государственного контроля выявил многочисленные нарушения при проверке торговых объектов в Гродненской и Могилевской областях. Работа ряда объектов приостановлена. Особо грубые нарушения обнаружены в частном магазине в Краснополье. В продаже находились более 900 наименований товаров без маркировки и более 1200 наименований без информации об изготовителе, составе, размере и ценников. На отдельные товары отсутствовали документы, подтверждающие [&hellip;]">
                <meta itemprop="author" content="reform.news"/>
        <meta itemscope itemprop="mainEntityOfPage" itemType="https://schema.org/WebPage" itemid="https://reform.news/v-magazine-krasnopolja-nashli-tysjachi-tovarov-bez-markirovki-i-cennikov" content="В магазине Краснополья нашли тысячи товаров без маркировки и ценников">
