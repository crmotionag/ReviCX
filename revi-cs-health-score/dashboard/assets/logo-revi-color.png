            <div class="post-card__thumbnail">
                <img width="500" height="328" src="https://reform.news/wp-content/uploads/2025/03/05_02-500x328.jpg" class="attachment-reboot_small size-reboot_small wp-post-image" alt="" itemprop="image" decoding="async" />
                            </div>
        </a>
	
    <div class="post-card__body">

	    <div class="post-card__title" itemprop="name"><span itemprop="headline"><a href="https://reform.news/liki-belarusi-kto-predstavljaet-stranu">Лики Беларуси: кто представляет страну?</a></span></div><div class="post-card__meta"></div>
    </div>

            <meta itemprop="articleBody" content="С момента проведения президентских выборов 2020 года Беларусь находится в состоянии политической неопределенности, что особенно актуализировало вопрос о легитимности власти и о представлении страны на международной арене. Этот вопрос не ограничивается лишь внутренними политическими процессами, но также касается международного признания. Многие «проснувшиеся», заинтересовавшиеся политикой недавно, полагают, что поставленный в названии вопрос возник только после выборов [&hellip;]">
                <meta itemprop="author" content="Екатерина Кузнецова"/>
        <meta itemscope itemprop="mainEntityOfPage" itemType="https://schema.org/WebPage" itemid="https://reform.news/liki-belarusi-kto-predstavljaet-stranu" content="Лики Беларуси: кто представляет страну?">
    <meta itemprop="dateModified" content="2025-05-21">
    <meta itemprop="datePublished" content="2025-03-16T11:00:14+03:00">
    <div itemprop="publisher" itemscope itemtype="https://schema.org/Organization" style="display: none;"><div itemprop="logo" itemscope itemtype="https://schema.org/ImageObject"><img itemprop="url image" src="https://reform.news/wp-content/uploads/2020/04/old_logo_reform.svg" alt="REFORM.news (ранее REFORM.by)"></div><meta itemprop="name" content="REFORM.news (ранее REFORM.by)"><meta itemprop="telephone" content="+375173781608"><meta itemprop="address" content="ул. Мележа 1, помещение 330, офис 4, 220113, Минск, Беларусь"></div></div>

<div class="post-card post-card--grid w-animate" itemscope itemtype="http://schema.org/BlogPosting" data-animate-style="no">
